{
    "name"        : "oasis/aws-wrappers",
    "description" : "Wrappers for AWS SDK",
    "type"        : "library",
    "require"     : {
        "php"             : ">=8.5",
        "aws/aws-sdk-php" : "^3.22",
        "oasis/logging"   : "^3.0",
        "oasis/event"     : "^3.0",
        "symfony/cache"   : "^8.0",
        "psr/simple-cache": "^3.0"
    },
    "require-dev" : {
        "phpunit/phpunit"   : "^13",
        "league/uri"        : "^7.0",
        "symfony/yaml": "^8.0",
        "giorgiosironi/eris": "^1.1"
    },
    "license"     : "MIT",
    "authors"     : [
        {
            "name" : "Minhao Zhang",
            "email": "minhao.zhang@qq.com"
        }
    ],
    "autoload"    : {
        "psr-4": {
            "Oasis\\Mlib\\AwsWrappers\\": "src/AwsWrappers/",
            "Oasis\\Mlib\\Logging\\"    : "src/Logging/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Oasis\\Mlib\\AwsWrappers\\Test\\": "ut/",
            "Oasis\\Mlib\\AwsWrappers\\Test\\Unit\\": "ut/unit/",
            "Oasis\\Mlib\\AwsWrappers\\Test\\Integration\\": "ut/integration/"
        }
    }
}
